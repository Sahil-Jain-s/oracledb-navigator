# Copy this file to ~/.config/oracledb-navigator/.env, then fill these values.
# Copy odb.config.example.json to ~/.config/oracledb-navigator/odb.config.json.

APP_ORACLE_USER=APP_READONLY
APP_ORACLE_PASSWORD=change_me
APP_ORACLE_CONNECT_STRING=localhost:1521/XEPDB1

WAREHOUSE_ORACLE_USER=WAREHOUSE_READONLY
WAREHOUSE_ORACLE_PASSWORD=change_me
WAREHOUSE_ORACLE_SCHEMA=WAREHOUSE_OWNER
WAREHOUSE_ORACLE_CONNECT_STRING=localhost:1521/XEPDB1

# Optional: define connections entirely in one environment variable.
# The value should be a JSON object whose keys are connection names.
#
# ORACLEDB_NAVIGATOR_CONNECTIONS={"app":{"userEnv":"APP_ORACLE_USER","passwordEnv":"APP_ORACLE_PASSWORD","schema":"APP_OWNER","connectStringEnv":"APP_ORACLE_CONNECT_STRING"}}
